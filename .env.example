# ── STST Python Runtime — Environment Variables ────────────────────────────
# Copy this file to .env at the repo root and fill in your values.
# The .env file is gitignored — never commit real secrets.

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── OKX Demo Trading (paper broker) ───────────────────────────────────────
# Create demo keys at: https://www.okx.com/demo-trading
# Demo keys are completely separate from live keys — safe to use here.
OKX_API_KEY=your-okx-demo-api-key
OKX_API_SECRET=your-okx-demo-api-secret
OKX_PASSPHRASE=your-okx-demo-passphrase

# ── Runtime mode ───────────────────────────────────────────────────────────
# PAPER = paper trading via OKX demo (default + only safe option right now)
# LIVE  = real orders — DO NOT set unless you have fully reviewed M8 gates
STST_MODE=PAPER

# ── Dataset IDs (optional overrides — defaults match docs/DATASETS.md) ─────
# STST_ACTIVE_DATASET_ID=CC_MAJORSPOTPERP_USDT_MAXDEPTH_2026_SUPABASE_V1
# STST_OKX_DATASET_ID=OKX_MAJORSPOTPERP_USDT_2022_2026_SUPABASE_V2

# ── Ingestor tuning (optional) ─────────────────────────────────────────────
# STST_INGEST_BATCH_LIMIT=1000
# STST_INGEST_SLEEP_SECONDS=0.4
